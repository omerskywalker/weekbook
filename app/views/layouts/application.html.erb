<!DOCTYPE html>
<html>
  <head>
    <title>Weekbook</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <main class="container mx-auto mt-28 px-5 flex">
    <nav class="border-b bg-white">
  <div class="mx-auto max-w-5xl px-4 py-3 flex items-center justify-between">
    <%= link_to "Weekbook", root_path, class: "font-semibold tracking-tight" %>

    <div class="flex items-center gap-3 text-sm">
      <% if user_signed_in? %>
        <%= link_to "Profile", "#", class: "hover:underline" %>
        <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "hover:underline" %>
      <% else %>
        <%= link_to "Sign in", new_user_session_path, class: "hover:underline" %>
        <%= link_to "Sign up", new_user_registration_path, class: "hover:underline" %>
      <% end %>
    </div>
  </div>
</nav>
      <%= yield %>
    </main>
  </body>
</html>
